# ===========================================
# Corporate LLM Platform — Environment Config
# ===========================================
# Diese Datei kopierst du zu ".env" und füllst die Werte aus.
# Die .env-Datei wird NIE eingecheckt (siehe .gitignore).

# --- LLM Provider Keys ---
# Anthropic API Key holst du dir hier: https://console.anthropic.com/
# Optional: leer lassen → Demo funktioniert dann nur mit Ollama (lokal)
ANTHROPIC_API_KEY=

# Optional für Phase 4 — kannst du leer lassen
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# --- App Settings ---
APP_NAME=Verinaris
APP_ENV=development
APP_DEBUG=true

# Default-Modell (überschreibbar pro Request)
# Wenn ANTHROPIC_API_KEY leer ist: setze hier ein Ollama-Modell, z.B. qwen2.5:7b
DEFAULT_MODEL=claude-sonnet-4-6
DEFAULT_MAX_TOKENS=1024

# --- Datenbank ---
DATABASE_URL=sqlite:///./data/platform.db

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Auth (Phase 2a) ---
# JWT_SECRET: lange zufällige Zeichenkette generieren!
# Beispiel: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=ersetze-mich-durch-zufaelligen-string
JWT_EXPIRE_HOURS=24

# Bootstrap-Admin wird beim ersten App-Start angelegt
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe-bitte-aendern
